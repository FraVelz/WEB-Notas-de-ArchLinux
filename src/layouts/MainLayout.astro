---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Guía completa sobre Arch Linux" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="text-xl font-bold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300">
            Notas de Arch Linux
          </a>
          <div class="flex space-x-4">
            <a href="/" class="text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 px-3 py-2 rounded-md text-sm font-medium">
              Inicio
            </a>
          </div>
        </div>
      </div>
    </nav>
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-center text-sm text-gray-600 dark:text-gray-400">
          Actualización: 0.0.6 | Autor: Fravelz
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
  }
  
  h1 {
    @apply text-4xl font-bold mb-6 mt-8;
  }
  
  h2 {
    @apply text-3xl font-semibold mb-4 mt-6;
  }
  
  h3 {
    @apply text-2xl font-semibold mb-3 mt-5;
  }
  
  h4 {
    @apply text-xl font-semibold mb-2 mt-4;
  }
  
  p {
    @apply mb-4 leading-relaxed;
  }
  
  ul, ol {
    @apply mb-4 ml-6;
  }
  
  li {
    @apply mb-2;
  }
  
  a {
    @apply text-blue-600 dark:text-blue-400 hover:underline;
  }
  
  code {
    @apply bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded text-sm font-mono;
  }
  
  pre {
    @apply bg-gray-900 dark:bg-gray-950 p-4 rounded-lg overflow-x-auto mb-4;
  }
  
  pre code {
    @apply bg-transparent p-0 text-gray-100;
  }
  
  blockquote {
    @apply border-l-4 border-blue-500 pl-4 italic my-4;
  }
  
  hr {
    @apply my-8 border-gray-300 dark:border-gray-700;
  }
  
  img {
    @apply max-w-full h-auto rounded-lg my-4;
  }
  
  table {
    @apply w-full border-collapse mb-4;
  }
  
  th, td {
    @apply border border-gray-300 dark:border-gray-700 px-4 py-2;
  }
  
  th {
    @apply bg-gray-100 dark:bg-gray-800 font-semibold;
  }
</style>
